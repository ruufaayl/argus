# ============================================================
# PAKISTAN SENTINEL — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ============================================================

# --- Cesium ---
VITE_CESIUM_ION_TOKEN=           # Free 50GB/month at ion.cesium.com

# --- AI Entity ---
CLAUDE_API_KEY=                  # Anthropic console

# --- Live Data APIs ---
OPENSKY_USERNAME=                # Free at opensky-network.org
OPENSKY_PASSWORD=
OPENAQ_API_KEY=                  # Free at openaq.org
HERE_API_KEY=                    # Free 250k transactions at developer.here.com
TOMTOM_API_KEY=                  # Free 2500 calls/day at developer.tomtom.com

# --- Infrastructure ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
R2_BUCKET_NAME=sentinel-tiles
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
NEON_DATABASE_URL=

# --- Auth (for classified mode) ---
CLASSIFIED_PASSWORD=             # 4-digit PIN for classified mode
JWT_SECRET=                      # Generate: openssl rand -hex 32

# ════════════════════════════════════════════════════════════
# v5.0 NEW API KEYS
# ════════════════════════════════════════════════════════════

# --- AISstream (Maritime Vessel Tracking) ---
# Register free at https://aisstream.io
AISSTREAM_KEY=

# --- OpenWeatherMap ---
# Register at https://openweathermap.org/api
OPENWEATHER_API_KEY=

# --- Sentinel Hub / Copernicus (Satellite Imagery) ---
# Register at https://dataspace.copernicus.eu
# Dashboard → OAuth clients → Create new
SENTINELHUB_CLIENT_ID=
SENTINELHUB_CLIENT_SECRET=
